---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';

const chapters = (await getCollection('chapters')).sort((a, b) =>
  a.id.localeCompare(b.id)
);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

function extractTitle(body: string | undefined, id: string) {
  const match = body?.match(/^#\s+(.+)$/m);
  return match ? match[1] : id;
}
---

<Layout>
  <h1>{SITE_TITLE}</h1>
  <p class="muted">第1巻・全{chapters.length}章</p>
  <ol class="toc">
    {chapters.map((chapter) => (
      <li>
        <a href={`${base}chapters/${chapter.id}/`}>
          {extractTitle(chapter.body, chapter.id)}
        </a>
      </li>
    ))}
  </ol>
</Layout>
